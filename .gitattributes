# Normalize line endings for all files
* text=auto

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Force LF for shell scripts
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
